public static String reverseSentence(String str){
        String s="";
        int end=str.length()-1;
        for(int i=str.length()-1;i>=0;i--){
            if(i==0 || str.charAt(i-1)==' '){
                for(int j=i;j<=end;j++){
                    s+=str.charAt(j);
                }
                s=s+" ";
                end=i-2;
            }
        }
        return s;
    }
