 public static String singleSpacing(String str){
        String s="";
        boolean flag=false;
        for(int i=0;i<str.length();i++){
            char ch=str.charAt(i);
            if(ch!=' ') {
                s=s+ch;
                flag=false;
            }
            else{
                if(flag) continue;
                else {
                    s = s + ch;
                    flag = true;
                }
            }
        }
        return s;
    }
